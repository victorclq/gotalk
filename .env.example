# --- Neon Postgres connection string ---
# Create a project at https://console.neon.tech and paste the pooled connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Anthropic (Claude) API ---
# Generates exercises, vocabulary, reading passages, lessons, and grades your free-text answers.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Optional model override. Defaults to claude-opus-4-8 (sharpest tutoring & grading).
# For lower cost set claude-sonnet-4-6 (good balance) or claude-haiku-4-5 (cheapest).
ANTHROPIC_MODEL="claude-opus-4-8"

# Public app URL
APP_URL="http://localhost:3100"
